

generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}


model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks Task[]
}


model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String
  priority    String
  category    String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  aiLogs      Ailog[]
}

model Ailog{
  id String @id @default(uuid())
  taskId String
  task Task @relation(fields: [taskId], references: [id])
  prompt String
  response String
  model String
  createdAt DateTime @default(now())
}